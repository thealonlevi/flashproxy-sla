# Copy to terraform.tfvars (gitignored) and fill in with YOUR values.
# Secrets can also be supplied via TF_VAR_* env vars instead of this file.
# NEVER commit a real terraform.tfvars — *.tfvars is gitignored for that reason.

ssh_public_key = "ssh-ed25519 AAAA... you@host"
admin_cidr     = "203.0.113.10/32" # your IP for break-glass SSH

ch_url              = "https://ch.flashproxy.com"
ch_worker_password  = "REDACTED-from-the-clickhouse-deploy-step"
ch_website_password = "REDACTED-from-the-clickhouse-deploy-step"

# package -> http://USER:PASS@HOST:PORT  (use your own proxy credentials)
proxy_urls = {
  "isp"             = "http://USER:PASS@isp.example.com:30"
  "datacenter"      = "http://USER:PASS@dc.example.com:777"
  "ipv6-residential" = "http://USER:PASS@ipv6.example.com:30"
  "ipv6-datacenter" = "http://USER:PASS@ipv6-dc.example.com:50"
  "isp_eu"          = "http://USER:PASS@isp-eu.example.com:30"
}
