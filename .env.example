# Copy to .env and fill in. Used by docker-compose and the demo worker.
# Proxy URL for the demo worker (the one package it probes locally):
ISP_PROXY_URL=http://USER:PASS@HOST:30

# Optional: Discord webhook for status-change alerts (worker monitor).
DISCORD_WEBHOOK=

# Integrity ledger signing key (Ed25519). Generate a keypair with:
#   go run ./cmd/keygen
# Put the PRIVATE seed here (base64) so the monitor worker signs checkpoints, and
# publish the PUBLIC key to the website (LEDGER_PUBKEY) so anyone can verify.
# Leave empty to run without signed checkpoints (chain still recorded).
LEDGER_SIGNING_KEY=
LEDGER_PUBKEY=
