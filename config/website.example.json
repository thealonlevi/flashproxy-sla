{
  "listen": "0.0.0.0:8080",
  "web_dir": "web",
  "site_url": "https://status.flashproxy.com",
  "tls_cert_file": "",
  "tls_key_file": "",
  "ledger_pubkey": "${LEDGER_PUBKEY}",
  "clickhouse": {
    "url": "http://127.0.0.1:18123",
    "db": "sla",
    "user": "flashproxy-status-website",
    "password": "${SLA_WEBSITE_PASSWORD}"
  },
  "public_clickhouse": {
    "url": "${SLA_PUBLIC_CH_URL}",
    "db": "sla",
    "user": "flashproxy-status-public",
    "password": "${SLA_PUBLIC_PASSWORD}",
    "note": "Read-only, resource-capped. Published so anyone can reproduce this dashboard and verify the integrity ledger (see /api/meta)."
  },
  "slo": {
    "degraded_avg_ms": 50,
    "degraded_for_min": 5,
    "down_success_pct": 90,
    "stale_seconds": 120
  }
}
