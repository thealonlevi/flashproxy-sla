{
  "listen": "0.0.0.0:8080",
  "web_dir": "web",
  "site_url": "https://status.flashproxy.com",
  "tls_cert_file": "",
  "tls_key_file": "",
  "clickhouse": {
    "url": "http://127.0.0.1:18123",
    "db": "sla",
    "user": "flashproxy-status-website",
    "password": "${SLA_WEBSITE_PASSWORD}"
  },
  "public_clickhouse": {
    "url": "${SLA_PUBLIC_CH_URL}",
    "db": "sla",
    "user": "flashproxy-status-public",
    "password": "${SLA_PUBLIC_PASSWORD}",
    "note": "Read-only, capped at 500 concurrent queries. Published so anyone can reproduce this dashboard from the same data."
  },
  "slo": {
    "connect_ms_median_warn": 120,
    "connect_ms_median_crit": 400,
    "success_pct_warn": 98.0,
    "success_pct_crit": 90.0,
    "stale_seconds": 120
  }
}
