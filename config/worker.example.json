{
  "vantage": "us-east",
  "timeout_ms": 8000,
  "monitor": true,
  "discord_webhook": "${DISCORD_WEBHOOK}",
  "clickhouse": {
    "url": "http://127.0.0.1:18123",
    "db": "sla",
    "user": "flashproxy-status-worker",
    "password": "${SLA_WORKER_PASSWORD}"
  },
  "slo": {
    "connect_ms_median_warn": 120,
    "connect_ms_median_crit": 400,
    "success_pct_warn": 98.0,
    "success_pct_crit": 90.0,
    "stale_seconds": 120
  },
  "targets": [
    { "package": "isp",             "proxy_url": "${ISP_PROXY_URL}",        "connect_target": "www.google.com:443",  "origin_get": "", "ip_version": 4, "interval_ms": 20000 },
    { "package": "datacenter",      "proxy_url": "${DC_PROXY_URL}",         "connect_target": "www.google.com:443",  "origin_get": "", "ip_version": 4, "interval_ms": 20000 },
    { "package": "ipv6",            "proxy_url": "${IPV6_PROXY_URL}",       "connect_target": "www.google.com:443",  "origin_get": "", "ip_version": 6, "interval_ms": 20000 },
    { "package": "ipv6-datacenter", "proxy_url": "${IPV6_DC_PROXY_URL}",    "connect_target": "www.google.com:443",  "origin_get": "", "ip_version": 6, "interval_ms": 20000 },
    { "package": "isp_eu",          "proxy_url": "${ISP_EU_PROXY_URL}",     "connect_target": "www.google.com:443",  "origin_get": "", "ip_version": 4, "interval_ms": 20000 }
  ]
}
