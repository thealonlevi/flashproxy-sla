# Built binaries (root-anchored so they don't match cmd/origin, cmd/worker, etc.)
/bin/
/out/
/origin
/collector
/prober
/worker
/website

# Real (non-example) configs — secrets / live endpoints.
# Only *.example.json is committed.
/config/*.json
!/config/*.example.json
!/config/*.docker.json
*.local.json

# Env files
.env
.env.*
!.env.example

# terraform
*.tfvars
.terraform/
*.tfstate*
